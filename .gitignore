# ── 数据集（体积大，从网络下载或手动放置） ──────────────────────────────────
data/

# ── 实验产出（模型权重、样本图像、日志） ────────────────────────────────────
experiments/

# ── 终端滚动日志（本地调试产物） ─────────────────────────────────────────────
*.log

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── 虚拟环境 ─────────────────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── macOS 系统文件 ────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── 编辑器 ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/*.ipynb

# ── PyTorch 权重（以防 experiments/ 之外也生成了零散 .pt） ───────────────────
*.pt
*.pth
